# =============================================================================
# .dockerignore — exclude files that should NOT be sent to the Docker build context
# Keeping the context small speeds up builds and avoids leaking local state.
# =============================================================================

# ---- .NET build artefacts ---------------------------------------------------
**/obj/
**/bin/
DFile.backend/publish/
publish/

# ---- Node / Next.js artefacts -----------------------------------------------
**/node_modules/
DFile.frontend/.next/
DFile.frontend/out/

# ---- IDE & OS files ---------------------------------------------------------
**/.vs/
**/.vscode/
.idea/
*.user
*.suo
.DS_Store
Thumbs.db

# ---- Git --------------------------------------------------------------------
.git/
.gitignore

# ---- Docs & non-essential files ---------------------------------------------
docs/
README.md
*.md

# ---- Local env overrides (never copy credentials into the image) ------------
**/appsettings.Development.json
**/.env.local
**/.env.*.local
